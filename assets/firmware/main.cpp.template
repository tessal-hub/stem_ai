void AppMainLoopStep() {
  ImuFrame frame{};
  if (!ReadImuFrame(&frame)) {
    return;
  }

  const SpellId spell = RunInference(frame);
  if (spell != SpellId::UNKNOWN) {
    OnSpellDetected(spell);
  }
}

bool InitializeSpellRuntime() {
  return InitI2cBus() && InitMpu6050() && InitInference();
