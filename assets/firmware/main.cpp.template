static SpellId RunInference(const ImuFrame& frame) {
  if (s_input == nullptr || s_output == nullptr || s_interpreter == nullptr) {
    return SpellId::UNKNOWN;
  }

  memmove(s_input_buffer,
          s_input_buffer + CHANNELS,
          (BUFFER_LENGTH - CHANNELS) * sizeof(float));

  s_input_buffer[BUFFER_LENGTH - 6] = frame.ax;
  s_input_buffer[BUFFER_LENGTH - 5] = frame.ay;
  s_input_buffer[BUFFER_LENGTH - 4] = frame.az;
  s_input_buffer[BUFFER_LENGTH - 3] = frame.gx;
  s_input_buffer[BUFFER_LENGTH - 2] = frame.gy;
  s_input_buffer[BUFFER_LENGTH - 1] = frame.gz;

  s_sample_count++;
  if (s_cooldown > 0) {
    s_cooldown--;
  }

  if (s_sample_count < WINDOW_SIZE || s_cooldown > 0) {
    return SpellId::UNKNOWN;
  }

  const float in_scale = s_input->params.scale;
  const int in_zp = s_input->params.zero_point;
  for (int i = 0; i < BUFFER_LENGTH; ++i) {
    int val = static_cast<int>(s_input_buffer[i] / in_scale + in_zp);
    val = val > 127 ? 127 : val;
    val = val < -128 ? -128 : val;
    s_input->data.int8[i] = static_cast<int8_t>(val);
  }

  if (s_interpreter->Invoke() != kTfLiteOk) {
    ESP_LOGE(TAG, "Invoke failed");
    return SpellId::UNKNOWN;
  }

  const float out_scale = s_output->params.scale;
  const int out_zp = s_output->params.zero_point;
  float max_prob = 0.0f;
  int max_idx = -1;
  for (int i = 0; i < static_cast<int>(kSpellClassCount); ++i) {
    const float prob = (s_output->data.int8[i] - out_zp) * out_scale;
    if (prob > max_prob) {
      max_prob = prob;
      max_idx = i;
    }
  }

  if (max_prob > 0.85f && max_idx >= 0 && max_idx != kIdleClassIndex) {
    s_cooldown = WINDOW_SIZE;
    return SpellFromIndex(max_idx);
  }

  return SpellId::UNKNOWN;
}

